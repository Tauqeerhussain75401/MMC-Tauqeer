        internal static DataTable AdmInfo(string regAlpha, string regNum)
        {
            string sql = @"SELECT regnoalpha, regnonumeric,admissionid, admdate, admtime, get_roomtitle(roomid) roomTitle,get_patienttype( patienttype) patienttype,get_consultantname(consultantid) ConsultantName,
                            title || patientname patientname ,
                            gender, to_char(To_Number(age)) || ' ' || SubStr(ymd,1,1) age,remarks,dischargeyn as discyn,dischargedate as discdate , referencename FROM  admissioninfo  WHERE regnoAlpha = '" + regAlpha + "' AND regnonumeric = '" + regNum + "' AND status = 0 ";
            DataTable dt = getData(sql);

