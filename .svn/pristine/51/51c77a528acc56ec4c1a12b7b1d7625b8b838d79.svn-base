    public partial class PTPackages : Form
    {
        public PTPackages()
        {
            InitializeComponent();

        }

        void FillQuery()
        {


            DataTable dtQuery = Query.PackageInfo();
            for (int i = 0; i < dtQuery.Rows.Count; i++)
            {
                dgvSearch.Rows.Add(dtQuery.Rows[i]["package_id"].ToString(),
                dtQuery.Rows[i]["packagename_name"].ToString(),
                dtQuery.Rows[i]["amount"].ToString(),
                dtQuery.Rows[i]["isdeactivate"].ToString() == "0" ? true : false,
                dtQuery.Rows[i]["createdby"].ToString(),
                dtQuery.Rows[i]["editby"].ToString(),
                dtQuery.Rows[i]["createtime"],
                dtQuery.Rows[i]["edittime"],

                dtQuery.Rows[i]["status"].ToString(),
                dtQuery.Rows[i]["terminalid"].ToString());



            }
        }

        private void PTPackages_Load(object sender, EventArgs e)
        {

            FillQuery();
            FillControls.FillcmbTest(cmbSurgery, 16);
        }

        //internal void Loadsurgery()
