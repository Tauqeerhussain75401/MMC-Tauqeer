       internal static void FillUSer(ComboBox cmb)
       {
           DataTable Users = new DataTable();
           Users = Query.UserLoginIndex();
           cmb.DataSource = Users;

           DataRow rw = Users.NewRow();
           rw["userid"] = "All";
           Users.Rows.InsertAt(rw, 0);

           cmb.DisplayMember = "userid";
           cmb.ValueMember = "userid";
           cmb.SelectedValue = "All";
       }

