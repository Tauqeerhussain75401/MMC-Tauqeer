       internal static void FillcmbCatagoryTest(ComboBox cmb, string id)
       {

           DataTable dtCataGoryTest = new DataTable();
           cmb.DataSource = dtCataGoryTest;
           if (id == "All")
           {

               dtCataGoryTest.Columns.Add("Title", typeof(String));
               dtCataGoryTest.Columns.Add("Id", typeof(String));
               DataRow rw = dtCataGoryTest.NewRow();
               rw["Title"] = "All";
               rw["Id"] = "All";
               dtCataGoryTest.Rows.InsertAt(rw, 0);
             } 
           else
           {
               dtCataGoryTest = Query.TestTypeId(id);
               DataRow rw = dtCataGoryTest.NewRow();
               rw["Title"] = "All";
               rw["Id"] = "All";
               dtCataGoryTest.Rows.InsertAt(rw, 0);
           
           }

           cmb.DataSource = dtCataGoryTest;
           cmb.DisplayMember = "Title";
           cmb.ValueMember = "Id";
       }

