         //           frmReportView.ShowBox("Voucher", Convert.ToDateTime(dtpDate.Value).ToString("dd-MMM-yyyy"), "RV", int.Parse(voucherNum).ToString("D6"), "Journal Voucher",txtEditBy.Text,txtStatus.Text);
