using System;
using System.Collections.Generic;
using System.Linq;
using System.Text;

namespace ERP
{
    class UserInfo
    {
        private static string _UserId;

        public static string UserId
        {
            get { return _UserId; }
            set { _UserId = value; }
        }

        private static string _UserName;

        public static string UserName
        {
            get { return UserInfo._UserName; }
            set { UserInfo._UserName = value; }
        }
        private static string _UserLevel;

        public static string UserLevel
        {
            get { return UserInfo._UserLevel; }
            set { UserInfo._UserLevel = value; }
        }


        private static DateTime _LogInDateTime;

        public static DateTime LogInDateTime
        {
            get { return UserInfo._LogInDateTime; }
            set { UserInfo._LogInDateTime = value; }
        }

    }
}
