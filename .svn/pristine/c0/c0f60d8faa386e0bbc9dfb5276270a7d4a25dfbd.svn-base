using System;
using System.Collections.Generic;
using System.ComponentModel;
using System.Data;
using System.Drawing;
using System.Linq;
using System.Text;
using System.Windows.Forms;

namespace ERP.Forms
{
    public partial class frmLabReportEntry : Form
    {
        public frmLabReportEntry()
        {
            InitializeComponent();
        }
        void LoadPatientInfo()
        {
            if (cmbIOstatus.Text == "OPD")
            {
                DataTable dt = Query.OPDReceiptDetail(txtSlipNo.Text, "2");
                if (dt.Rows.Count > 0)
                {
                    txtReportNo.Text = "";
                    txtSlipDate.Text = ((DateTime)dt.Rows[0]["Vdate"]).ToString("dd-MMM-yyyy");
                    dtpIssueDate.Value = (DateTime)dt.Rows[0]["Vdate"];
                    txtPatientName.Text = dt.Rows[0]["patienttitle"].ToString() + dt.Rows[0]["patientname"].ToString();
                    txtAge.Text = dt.Rows[0]["age"].ToString() + " " + dt.Rows[0]["ageunit"].ToString();
                    txtGender.Text = dt.Rows[0]["gender"].ToString();
                    txtcontact.Text = dt.Rows[0]["contactno"].ToString();
                    //txtRefBy.Text = dt.Rows[0]["RefBy"].ToString();
                    //ConsultantId = dt.Rows[0]["contactno"].ToString();
                }
            }
            else
            {
                DataTable dt = Query.IPDReceiptDetail(txtSlipNo.Text, "2");
                if (dt.Rows.Count > 0)
                {
                    txtReportNo.Text = "";
                    txtSlipDate.Text = ((DateTime)dt.Rows[0]["admdate"]).ToString("dd-MMM-yyyy");
                    DataTable get_receipt_date = Query.getData("select receiptdate from inptestcharges WHERE receiptno='" + txtSlipNo.Text + "' and testtypeid='2' AND status!=1");

                    dtpIssueDate.Value = get_receipt_date.Rows.Count>0?(DateTime)get_receipt_date.Rows[0]["receiptdate"] : (DateTime)dt.Rows[0]["admdate"];
                    txtPatientName.Text = dt.Rows[0]["title"].ToString() + dt.Rows[0]["patientname"].ToString();
                    txtAge.Text = dt.Rows[0]["age"].ToString() + " " + dt.Rows[0]["ymd"].ToString();
                    txtGender.Text = dt.Rows[0]["gender"].ToString();
                    txtcontact.Text = dt.Rows[0]["emergency"].ToString();
                    txtRoom.Text = dt.Rows[0]["roomName"].ToString();
                    //txtRefBy.Text = dt.Rows[0]["RefBy"].ToString();
                    //ConsultantId = dt.Rows[0]["contactno"].ToString();
                    txtRegNo.Text = dt.Rows[0]["regno"].ToString();
                }
            }

            
        }

        bool FillDetail(string ReportNo, string SlipNo)
        {
            DataTable dt = Query.getData("select * from labreportmaster where SlipNo = '" + SlipNo + "' or ReportNo = '" + ReportNo + "'");
            Validation.Clear(this);
            if (dt.Rows.Count > 0)
                {
                    txtReportNo.Text = dt.Rows[0]["ReportNo"].ToString();
                    txtSlipNo.Text = dt.Rows[0]["SlipNo"].ToString();
                    dtpIssueDate.Value = (DateTime)dt.Rows[0]["issuedate"];
                    txtSlipDate.Text = dt.Rows[0]["slipdate"].ToString();
                    txtPatientName.Text = dt.Rows[0]["patientname"].ToString();
                    txtAge.Text = dt.Rows[0]["age"].ToString();
                    txtGender.Text = dt.Rows[0]["gender"].ToString();
                    txtcontact.Text = dt.Rows[0]["contact"].ToString();
                   // cmbIOstatus.Text = dt.Rows[0]["ipdopd"].ToString();
                    txtRefBy.Text = dt.Rows[0]["refby"].ToString();
                    cmbLocation.Text = dt.Rows[0]["location"].ToString();
                    //txtRefPhysician.Text = dt.Rows[0]["refphysician"].ToString();
                    return false;
                }
         
  

            return false;
        }
        bool FillTestDetail(string SlipNo,string DepartmentId)
        {
            DepartmentId = DepartmentId == null ? "" : DepartmentId;
            DataTable dtremarks = Query.getData("select remarks from labreportresult where reportno = '" + SlipNo + "' AND departmentid = '" + DepartmentId + "'AND STATUS = 0 and rownum = 1");
            if (dtremarks.Rows.Count > 0)
                txtRemarks.Text = dtremarks.Rows[0]["Remarks"].ToString();
            else txtRemarks.Text = "";

            DataTable dt;
            if (cmbIOstatus.Text == "OPD")
            {
                 dt = Query.getData("select tp.id,tp.title,Nvl(get_LabReportResultById(tp.id,'" + SlipNo + "'),tp.approxresult) result,tp.unit, tp.rangenewborn approxresult from testparameter tp where tp.testid IN (SELECT id FROM OPDReceiptTestepartments WHERE receiptno = '" + SlipNo + "' and departmentid = '" + DepartmentId + "' AND Nvl(status,0)=0)   ORDER BY To_Number(id) ");
            }
            else
            {
               
                dt = Query.getData("select tp.id,tp.title,Nvl(get_LabReportResultById(tp.id,'" + SlipNo + "'), tp.approxresult) result,tp.unit, tp.rangenewborn approxresult from testparameter tp where tp.testid IN ( SELECT t.id FROM ADMISSIONINFO  ad left JOIN inptestcharges iptc ON  iptc.serialno = ad.serialno left JOIN test t ON t.id = iptc.testid left JOIN departments d ON d.id = t.testheadid WHERE  iptc.receiptno = '" + SlipNo + "' AND d.id = '" + DepartmentId + "' AND Nvl(iptc.status,0)=0)   ORDER BY To_Number(tp.id)");
            }

            dgvTestParameters.Rows.Clear(); 
            for (int i = 0; i < dt.Rows .Count ; i++)
			{
			 dgvTestParameters.Rows .Add (dt.Rows [i]["id"].ToString(),
                 dt.Rows [i]["Title"].ToString(),
                 dt.Rows [i]["Result"].ToString(),
                 dt.Rows [i]["Unit"].ToString(),
                 dt.Rows[i]["ApproxResult"].ToString());
			}                
             //   return true;            
            return true ;
        }
        private void txtSlipNo_Validated(object sender, EventArgs e)
        
{
            DataTable dt;
                if (cmbIOstatus.Text == "OPD")
               {   
                   dt = Query.OPDReceiptTestDepartmentIndex(txtSlipNo.Text);
              }
            else
             {
                  dt = Query.IPDReceiptTestDepartmentIndex(txtSlipNo.Text);
             }
            AllowValidate = false;
            cmbDepartment.DataSource = dt;
            cmbDepartment.DisplayMember = "DepartmentTitle";
            cmbDepartment.ValueMember = "DepartmentId";
            cmbDepartment.SelectedIndex = -1;
            AllowValidate = true;
            if (!FillDetail("", txtSlipNo.Text)) 
                LoadPatientInfo();
            if (cmbDepartment.Items.Count > 0)
                cmbDepartment.SelectedIndex = 0;
            
        }
        private void frmLabReportEntry_KeyDown(object sender, KeyEventArgs e)
        {
            if (e.KeyCode == Keys.Enter && !dgvTestParameters.Focused && !DgvShortList .Focused)
            
            {
                SendKeys.Send("{tab}");
            }
        }

        private void frmLabReportEntry_Load(object sender, EventArgs e)
        {
            cmbIOstatus.SelectedIndex = 0;
        }
        bool AllowValidate = false;
        private void cmbDepartment_SelectedIndexChanged(object sender, EventArgs e)
        {
            if (AllowValidate == true)
            {
                Cursor.Current = Cursors.WaitCursor;
                FillTestDetail(txtSlipNo.Text, (string)cmbDepartment.SelectedValue);
                Cursor.Current = Cursors.Default;
            }
        }

        private void btnSave_Click(object sender, EventArgs e)
        {
            string statusIO = cmbIOstatus.SelectedIndex == 0 ? "OPD" : "IPD";
            if (MessageBox.Show("Are you sure?" + Environment.NewLine + "You want to save this...!", "Confirmation", MessageBoxButtons.YesNo, MessageBoxIcon.Question) == DialogResult.Yes)
            {
                string ReportNo = "";
                DML.LabReportMaster_Add_Edit(txtReportNo.Text, txtSlipNo.Text, dtpIssueDate.Value, txtSlipDate.Text, txtPatientName.Text, txtAge.Text, txtGender.Text, txtcontact.Text,
                    (string )cmbDepartment .SelectedValue , txtRefBy.Text, (string )cmbLocation.SelectedValue  ,txtRemarks.Text  , "0", (string)cmbIOstatus.Text,ref ReportNo);
                foreach (DataGridViewRow item in dgvTestParameters.Rows )
                {
                    DML.LabReportResult_Add_Edit(txtSlipNo.Text, (string)cmbDepartment.SelectedValue, item.Cells[clnId.Index].Value.ToString(), item.Cells[clnTitle.Index].Value.ToString(), item.Cells[clnResult.Index].Value.ToString(), item.Cells[clnUnit.Index].Value.ToString(), txtRemarks.Text, item.Cells[clnApproxResult.Index].Value.ToString(), "0", statusIO.ToString()); 
                }
                //FillDetail(ReportNo, "");
                MessageBox.Show("Record Successfully Saved..!");
            }
        }

        private void btnPrint_Click(object sender, EventArgs e)
        {
            Reports.LabReport rpt = new Reports.LabReport();
            DataTable dt = ReportQuery.LabReportResult(txtSlipNo.Text ,(string )cmbDepartment.SelectedValue   );
            rpt.SetDataSource(dt);
            rpt.SetParameterValue("@companyname", CompanyInfo.CompanyName);
            rpt.SetParameterValue("@Contact", CompanyInfo.ContactHead);
            rpt.SetParameterValue("@Address", CompanyInfo.Address);
            rpt.SetParameterValue("@ServerDate", SoftwareInfo.ServerDate);
            rpt.SetParameterValue("@User", UserInfo.UserName);
            rpt.SetParameterValue("@ReportDate", dtpIssueDate.Value);
            rpt.SetParameterValue("@ReportNo", txtSlipNo.Text);
            rpt.SetParameterValue("@PatientName", txtPatientName.Text);
            rpt.SetParameterValue("@Gender", txtGender.Text + " / " + txtAge.Text);
            rpt.SetParameterValue("@PatientContact", txtcontact.Text);
            rpt.SetParameterValue("@RefBy", txtRefBy.Text);
            rpt.SetParameterValue("@Department", cmbDepartment.Text);
            rpt.SetParameterValue("@Remarks", txtRemarks.Text != "" ?  "Remarks : " + txtRemarks.Text : "");
            rpt.SetParameterValue("@regno", cmbIOstatus.Text == "IPD" ? "File" + ":" + txtRegNo.Text : "");
            rpt.PrintToPrinter(1, true, 1, 9999);                      
        }

        private void btnNew_Click(object sender, EventArgs e)
        {
            txtSlipNo.Text = ""; 
            DataTable dt = Query.OPDReceiptTestDepartmentIndex(txtSlipNo.Text);
            AllowValidate = false;
            cmbDepartment.DataSource = dt;
            cmbDepartment.DisplayMember = "DepartmentTitle";
            cmbDepartment.ValueMember = "DepartmentId";
            cmbDepartment.SelectedIndex = -1;
            if (cmbDepartment.Items.Count > 0)
                cmbDepartment.SelectedIndex = 0;
            AllowValidate = true;
            if (!FillDetail("", txtSlipNo.Text))
                LoadPatientInfo();
            txtSlipNo.Focus();    
        }

        private void btnPreview_Click(object sender, EventArgs e)
        {
            frmReportView frm = new frmReportView();
            Reports.LabReport rpt = new Reports.LabReport();
            DataTable dt = ReportQuery.LabReportResult(txtSlipNo.Text, (string)cmbDepartment.SelectedValue);
            rpt.SetDataSource(dt);
            rpt.SetParameterValue("@companyname", CompanyInfo.CompanyName);
            rpt.SetParameterValue("@Contact", CompanyInfo.ContactHead);
            rpt.SetParameterValue("@Address", CompanyInfo.Address);
            rpt.SetParameterValue("@ServerDate", SoftwareInfo.ServerDate);
            rpt.SetParameterValue("@User", UserInfo.UserName);
            rpt.SetParameterValue("@ReportDate", dtpIssueDate.Value);
            rpt.SetParameterValue("@ReportNo", txtSlipNo.Text);
            rpt.SetParameterValue("@PatientName", txtPatientName.Text);
            rpt.SetParameterValue("@Gender", txtGender.Text + " / " + txtAge.Text);
            rpt.SetParameterValue("@PatientContact", txtcontact.Text);
            rpt.SetParameterValue("@RefBy", txtRefBy.Text);
            rpt.SetParameterValue("@Department", cmbDepartment.Text);
            rpt.SetParameterValue("@Remarks", txtRemarks.Text != "" ? "Remarks : " + txtRemarks.Text : "");
            rpt.SetParameterValue("@Remarks", txtRemarks.Text != "" ? "Remarks : " + txtRemarks.Text : "");
            rpt.SetParameterValue("@regno", cmbIOstatus.Text == "IPD" ? "File" + ":" + txtRegNo.Text : "");
            rpt.SetParameterValue("@room", cmbIOstatus.Text == "IPD" ? "Room" + ":" + txtRoom.Text : "");

            frm.rptViewer.ReportSource = rpt;
            frm.Show();

        }
        int DgvCurrentRow = 0;
        private void dgvTestParameters_KeyDown(object sender, KeyEventArgs e)
        {
            if (e.KeyData == Keys.F3)
            {
                CurrentF3Control = "Grid";
                //this.DgvShortList.DataSource = (object)null;
                this.DgvCurrentRow = this.dgvTestParameters.CurrentRow.Index;
                string DepartmentId = (string )cmbDepartment .SelectedValue ;
                DataTable dt = Query.getData("SELECT id,REMARKS FROM testheadremarks WHERE departmentid = '"+DepartmentId +"'");  
                if (dt.Rows .Count > 0)
                {
                    this.DgvShortList.DataSource = dt;
                    this.DgvShortList.Visible = true;
                    this.DgvShortList.Columns[0].Visible = false;                   
                    this.DgvShortList.Columns[1].HeaderText = "Remarks";
                    this.DgvShortList.Columns[1].Width = 526;                   
                    this.DgvShortList.Columns[1].ReadOnly = true;
                    this.DgvShortList.CurrentCell = this.DgvShortList.Rows[0].Cells[1];
                    this.DgvShortList.BringToFront();
                    this.DgvShortList.Select();
                    this.DgvShortList.Show();
                    this.DgvShortList.Focus();
                }
                else
                {
                    //this.DgvShortList.Visible = false;
                    MessageBox.Show("!!! Remarks for selected Head - Not Found !!!", "NOT FOUND", MessageBoxButtons.OK, MessageBoxIcon.Hand);
                }
            }
            else if (e.KeyData == Keys.Escape)
            {
                this.dgvTestParameters.Focus();
                this.DgvShortList.Visible = false;
                this.DgvShortList.Hide();
                //this.DgvShortList.Refresh();
                //this.dgvTestParameters.Refresh();
                
            }
        }

        private void DgvShortList_KeyDown(object sender, KeyEventArgs e)
        {
            if (e.KeyData == Keys.Return)
            {
                if (CurrentF3Control == "Grid")
                {
                    this.dgvTestParameters.Rows[this.DgvCurrentRow].Cells[2].Value = this.DgvShortList.Rows[this.DgvShortList.CurrentRow.Index].Cells[1].Value;
                    this.dgvTestParameters.Focus();
                }
                else if (CurrentF3Control == "Remarks")
                {
                    txtRemarks .Text  = this.DgvShortList.Rows[this.DgvShortList.CurrentRow.Index].Cells[1].Value.ToString() ;
                    txtRemarks .Focus();
                }
                this.DgvShortList.Visible = false;
                
                this.DgvShortList.Hide();
               
            }
            else if (e.KeyData == Keys.Escape)
            {
                if (CurrentF3Control == "Grid")
                    this.dgvTestParameters.Focus();
                else if (CurrentF3Control == "Remarks")
                    txtRemarks.Focus();
                this.DgvShortList.Visible = false;
                this.DgvShortList.Hide();

            }
        }

        private void dgvTestParameters_Enter(object sender, EventArgs e)
        {
            dgvTestParameters.CurrentCell = dgvTestParameters.CurrentRow.Cells[clnResult.Index];    
        }
        string CurrentF3Control = "";
        private void txtRemarks_KeyDown(object sender, KeyEventArgs e)
        {
            if (e.KeyData == Keys.F3)
            {
                CurrentF3Control = "Remarks";
                string DepartmentId = (string)cmbDepartment.SelectedValue;
                DataTable dt = Query.getData("SELECT id,REMARKS FROM testheadremarks WHERE departmentid = '" + DepartmentId + "'");
                if (dt.Rows.Count > 0)
                {
                    this.DgvShortList.DataSource = dt;
                    this.DgvShortList.Visible = true;
                    this.DgvShortList.Columns[0].Visible = false;
                    this.DgvShortList.Columns[1].HeaderText = "Remarks";
                    this.DgvShortList.Columns[1].Width = 526;
                    this.DgvShortList.Columns[1].ReadOnly = true;
                    this.DgvShortList.CurrentCell = this.DgvShortList.Rows[0].Cells[1];
                    this.DgvShortList.BringToFront();
                    this.DgvShortList.Select();
                    this.DgvShortList.Show();
                    this.DgvShortList.Focus();
                }
                else
                {
                    //this.DgvShortList.Visible = false;
                    MessageBox.Show("!!! Remarks for selected Head - Not Found !!!", "NOT FOUND", MessageBoxButtons.OK, MessageBoxIcon.Hand);
                }
            }
            else if (e.KeyData == Keys.Escape)
            {
                txtRemarks.Focus();
                this.DgvShortList.Visible = false;
                this.DgvShortList.Hide();
                //this.DgvShortList.Refresh();
                //this.dgvTestParameters.Refresh();

            }
        }


        private void cmbIOstatus_SelectedIndexChanged(object sender, EventArgs e)
        {
            txtSlipNo.Text = "";
            txtSlipNo_Validated(null,null);
        }

    }
}
