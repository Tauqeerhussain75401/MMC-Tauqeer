        private void ManageControls(Control[] ctrl)
        {
            // int LocX = 12, LocY = 60;
            // LocY += 50;
            foreach (Control item in ctrl)
            {
                item.Visible = true;
                // item.Location = new Point(LocX, LocY);
                // LocY += item.Height + 3;
            }


