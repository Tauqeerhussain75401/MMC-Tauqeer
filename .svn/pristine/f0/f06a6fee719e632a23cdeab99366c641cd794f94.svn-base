        private void dgvAccount_EditingControlShowing(object sender, DataGridViewEditingControlShowingEventArgs e)
        {
            if (dgvAccount.CurrentCell.ColumnIndex == clnTitleofAccount.Index)
                ((ComboBox)e.Control).KeyDown += new KeyEventHandler(frmPVoucherNew_KeyDown);
            else if (e.Control is ComboBox)
                ((ComboBox)e.Control).KeyDown -= new KeyEventHandler(frmPVoucherNew_KeyDown);
        }
