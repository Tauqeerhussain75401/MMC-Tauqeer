        void Fillquery()
        {
            dgvQuery.Rows.Clear();
            for (int i = 0; i < dtquery.Rows.Count; i++)
            {
                dgvQuery.Rows.Add(Convert.ToDateTime(dtquery.Rows[i]["VDate"]).ToString("dd MMM yyyy"),
                          dtquery.Rows[i]["vtype"].ToString(),
                          dtquery.Rows[i]["VNO"].ToString(),
                          dtquery.Rows[i]["Narration"],
                          dtquery.Rows[i]["draccount"],
                          dtquery.Rows[i]["dr"],
                          dtquery.Rows[i]["craccount"],
                          dtquery.Rows[i]["cr"],
                          dtquery.Rows[i]["description"],
                          dtquery.Rows[i]["banktitle"]
                          );
            }
        }

        void FillqueryPost()
        {
            dgvPost.Rows.Clear();
            for (int i = 0; i < dtqueryPost.Rows.Count; i++)
            {
                dgvPost.Rows.Add(Convert.ToDateTime(dtqueryPost.Rows[i]["VDate"]).ToString("dd MMM yyyy"),
                dtqueryPost.Rows[i]["vtype"].ToString(),
                dtqueryPost.Rows[i]["VNO"].ToString(),
                dtqueryPost.Rows[i]["Narration"],
                dtqueryPost.Rows[i]["draccount"],
                dtqueryPost.Rows[i]["dr"],
                dtqueryPost.Rows[i]["craccount"],
                dtqueryPost.Rows[i]["cr"],
                dtqueryPost.Rows[i]["description"],
                dtqueryPost.Rows[i]["banktitle"]
                );
            }
        }

        void Fillquery1()
        {
            dgvQuery.Rows.Clear();
            for (int i = 0; i < dtquery.Rows.Count; i++)
            {
                dgvQuery.Rows.Add(Convert.ToDateTime(dtquery.Rows[i]["VDate"]).ToString("dd MMM yyyy"),
                    "RV-" + dtquery.Rows[i]["VNO"].ToString(),
                    dtquery.Rows[i]["Narration"],
                    dtquery.Rows[i]["Amount"],
                    dtquery.Rows[i]["VNO"]
                    );
            }
        }
        private void btnFind_Click(object sender, EventArgs e)
        {
            dgvQuery.Rows.Clear();

            try
            {
                dtquery = Query.PaymentFilter1withdate(dtpFrom.Value.ToString("dd MMM yyyy"), dtpTo.Value.ToString("dd MMM yyyy"),
                 (cmbFilterNarration.Text != "ALL" ? "  and fktransactionid = '" + Convert.ToString(cmbFilterNarration.SelectedValue) + "'" : ""),
                 (txtVno.Text != "" ? " and VNO = " + txtVno.Text : ""), cmbVouchers.Text, "Unpost");
                Fillquery();
