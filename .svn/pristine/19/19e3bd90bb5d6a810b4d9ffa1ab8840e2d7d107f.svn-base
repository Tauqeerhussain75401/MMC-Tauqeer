        private void btnPost_Click(object sender, EventArgs e)
        {
            //if (SaveRight == true)
            //{
            if (MessageBox.Show("Do you wan't to save changes?", "Confirmation", MessageBoxButtons.YesNo, MessageBoxIcon.Question) == DialogResult.Yes)
            {
                foreach (DataGridViewRow item in dgvQuery.SelectedRows)
                {
                    Query.MasterQueryEC("Update Voucherdetail set vdate = trunc(sysdate), status = 0,approvedby='" + Variable.UserId + "|" + Variable.TerminalId + "' where status = 2 and VNO = '" + item.Cells[VoucherNum.Index].Value.ToString() + "' AND vtype ='" + item.Cells[clnVtype.Index].Value.ToString() + "'");
                    dgvPost.Rows.Add(
                        item.Cells[Date.Index].Value.ToString(),
                        item.Cells[clnVtype.Index].Value.ToString(),
                        item.Cells[VoucherNum.Index].Value,
                        item.Cells[TransNarrationQ.Index].Value.ToString(),
                        item.Cells[clnDrAccount.Index].Value.ToString(),
                        item.Cells[clnDrAmount.Index].Value.ToString(),
                        item.Cells[clnCrAccount.Index].Value.ToString(),
                        item.Cells[clnCrAmount.Index].Value.ToString(),
                        item.Cells[clnDescrption.Index].Value.ToString(),
                        item.Cells[clnBankTitle.Index].Value.ToString()

                        //item.Cells[AmountQ.Index].Value.ToString(),
                        //item.Cells[PVNumberQ.Index].Value.ToString()
                        );

                    dgvQuery.Rows.Remove(item);
                }

                MessageBox.Show("Records Successfully Posted...!");

            }
            //}
            else
            {
                MessageBox.Show("You have no rights to save this...!");
            }
        }

        private void btnSelectAll_Click(object sender, EventArgs e)
        {
            dgvQuery.SelectAll();
        }

        private void btnDel_Click(object sender, EventArgs e)
        {
            //if (DeleteRight == true)
            //{
            if (MessageBox.Show("Do you wan't to Delete this?", "Confirmation", MessageBoxButtons.YesNo, MessageBoxIcon.Question) == DialogResult.Yes)
            {
                foreach (DataGridViewRow item in dgvQuery.SelectedRows)
                {
                    Query.MasterQueryEC("Update Voucherdetail set status = 1 where status = 2 and VNO = '" + item.Cells[VoucherNum.Index].Value.ToString() + "'");
                    dgvQuery.Rows.Remove(item);
                }
                MessageBox.Show("Records Successfully Deleted...!");
            }
            //}
            //else
            //{
            //    MessageBox.Show("You have no rights to save this...!");
            //}
        }

