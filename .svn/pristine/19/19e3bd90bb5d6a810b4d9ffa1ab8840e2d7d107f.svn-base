        private void btnUnPost_Click(object sender, EventArgs e)
        {
            //if (SaveRight == true)
            //{
            //if (Variable.UserId == "Admin")
            //{

            if (MessageBox.Show("Do you wan't to save changes?", "Confirmation", MessageBoxButtons.YesNo, MessageBoxIcon.Question) == DialogResult.Yes)
            {
                foreach (DataGridViewRow item in dgvPost.SelectedRows)
                {
                    Query.MasterQueryEC("Update Voucherdetail set status = 2 where status = 0 and VNO = '" + item.Cells[clnPostVNo.Index].Value.ToString() + "' and vtype='" + item.Cells[clnPostVType.Index].Value.ToString() + "'");
                    dgvQuery.Rows.Add(
                        item.Cells[clnPostDate.Index].Value.ToString(),
                        item.Cells[clnPostVType.Index].Value.ToString(),
                        item.Cells[clnPostVNo.Index].Value,
                        item.Cells[clnPostNarration.Index].Value.ToString(),
                        item.Cells[clnPostDrAccount.Index].Value.ToString(),
                        item.Cells[clnPostDrAmount.Index].Value.ToString(),
                        item.Cells[clnPostCrAccount.Index].Value.ToString(),
                        item.Cells[clnPostDescrption.Index].Value.ToString(),
                        item.Cells[clnPostBankTitle.Index].Value.ToString());
                    dgvPost.Rows.Remove(item);
                }
                MessageBox.Show("Records Successfully UnPosted...!");
            }
            // }
            //    else
            //    {
            //        MessageBox.Show("Pls Login from Admin to UnPost...!");
            //    }


            //}
            else
            {
                MessageBox.Show("You have no rights to Unpost this...!");
            }
        }

