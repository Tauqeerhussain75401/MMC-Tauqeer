        public void showdata()
        {

            try
            {
                //  string filterQuery = "select convert(varchar, VDate, 103) as VDate,VNO,(select TransNarration from TransactionCode where ID = FK_Narration) as Narration,sum(debit) as Amount from [GL_2017-2018] where FK_Narration = " + (cmbFilterNarration.Text != "ALL" ? "'" + cmbFilterNarration.SelectedValue.ToString() + "'" : "FK_Narration") + " and VNO = " + VNO + "  and Vtype = 'PV' and status = 2  group by convert(varchar, VDate, 103) ,VNO,FK_Narration";
                dtquery = Query.PaymentFilterAll((cmbFilterNarration.Text != "ALL" ? "  and fktransactionid = '" + Convert.ToString(cmbFilterNarration.SelectedValue) + "'" : ""),
                    (VNO != "" ? " and VNO = " + VNO : ""), "Unpost");
                Fillquery();
            }
            catch (Exception ex)
            {
                MessageBox.Show(ex.Message.ToString());
                Errors.writeline(ex.Message.ToString(), "Payment_btnFind_Click");
            }
        }
