        private void dgvQuery_CellDoubleClick(object sender, DataGridViewCellEventArgs e)
        {


            if (dgvQuery.SelectedRows[0].Cells[clnVtype.Index].Value.ToString() == "PV")
            {
                frmPVoucherNew payment = new frmPVoucherNew();
                payment.Show();
                payment.FillDetail(dgvQuery.SelectedRows[0].Cells[VoucherNum.Index].Value.ToString());
                payment.tabJournalQuery.Enabled = false;
            }
            else if (dgvQuery.SelectedRows[0].Cells[clnVtype.Index].Value.ToString() == "RV")
            {

                frmRVoucherNew receipt = new frmRVoucherNew();
                receipt.Show();
                receipt.FillDetail(dgvQuery.SelectedRows[0].Cells[VoucherNum.Index].Value.ToString());
                receipt.tabJournalQuery.Enabled = false;
            }
            else if (dgvQuery.SelectedRows[0].Cells[clnVtype.Index].Value.ToString() == "JV")
            {
                

                frmGeneralVoucher2 general = new frmGeneralVoucher2();
                general.Show();
                general.FillDetail(dgvQuery.SelectedRows[0].Cells[VoucherNum.Index].Value.ToString());
                general.tabJournalQuery.Enabled = false;
            }
        }





