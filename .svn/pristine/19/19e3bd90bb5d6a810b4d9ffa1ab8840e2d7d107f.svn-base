        private void btnPostFind_Click(object sender, EventArgs e)
        {
            dgvPost.Rows.Clear();

            try
            {
                dtqueryPost = Query.PaymentFilter1withdate(dtpPostFrom.Value.ToString("dd MMM yyyy"), dtpPostTo.Value.ToString("dd MMM yyyy"),
                 (cmbPostFilterNarration.Text != "ALL" ? "  and fktransactionid = '" + Convert.ToString(cmbPostFilterNarration.SelectedValue) + "'" : ""),
                 (txtPostVNo.Text != "" ? " and VNO = " + txtPostVNo.Text : ""), cmbPostVtype.Text, "Post");
                FillqueryPost();
            }
            catch (Exception ex)
            {
                MessageBox.Show(ex.Message.ToString());
                Errors.writeline(ex.Message.ToString(), "Payment_btnFind_Click");
            }
        }

