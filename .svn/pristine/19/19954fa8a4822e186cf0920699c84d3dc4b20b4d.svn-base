using System;
using System.Collections.Generic;
using System.ComponentModel;
using System.Data;
using System.Drawing;
using System.Linq;
using System.Text;
using System.Windows.Forms;

namespace ERP
{
    public partial class frmChartOfAcc : Form
    {
        DataTable dtChart;
        DataTable dtFilter;
        DataTable dtaccountitle;
        public bool SaveRight;

        public frmChartOfAcc()
        {
            InitializeComponent();
        }
        bool FlogIn = true;
        void Fill()
        {
            tvChartOfAcc.Nodes.Clear();
            dtChart = Query.get_ChartOfAcc();
            dtFilter = dtChart.Copy();
            dtFilter.Rows.Clear();
            dtChart.PrimaryKey = new DataColumn[] { dtChart.Columns["Account"] };
            tvChartOfAcc.Nodes.Add("0", "Chart Of Account", null);
            for (int i = 0; i < dtChart.Rows.Count; i++)
            {

                //tvChartOfAcc.SelectedNode = tvChartOfAcc.Find(o => o.Name == dtChart.Rows[i]["parentid"].ToString());
                string ParentId = dtChart.Rows[i]["parentid"].ToString();
                tvChartOfAcc.SelectedNode = tvChartOfAcc.Nodes.Find(ParentId, true).FirstOrDefault();
                tvChartOfAcc.SelectedNode.Nodes.Add(dtChart.Rows[i]["Account"].ToString(), dtChart.Rows[i]["Title"].ToString());


            }


            tvChartOfAcc.CollapseAll();
            tvChartOfAcc.Nodes[0].Expand();
        }
        DataTable dtSecpAccounts = new DataTable();

        private void frmChartOfAccount_Load(object sender, EventArgs e)
        {
            dtSecpAccounts = Query.getData("select * from secp_COA");
            dtaccountitle = Query.getData(" SELECT  accountid,accounttitle FROM chartofaccounts WHERE status=0   AND aclevel=5 ");
            Fill();
            FlogIn = false;
            Filldgv();
        }

        void Filldgv()
        {
            if (!FlogIn)
            {
                lblParentHeader.Text = tvChartOfAcc.SelectedNode.Text;
                dtFilter.Rows.Clear();
                if (tvChartOfAcc.SelectedNode != null)
                    dtFilter = dtChart.Select("parentid = '" + tvChartOfAcc.SelectedNode.Name + "'").Count() > 0 ? dtChart.Select("parentid = '" + tvChartOfAcc.SelectedNode.Name + "'").CopyToDataTable() : dtFilter;

                if (tvChartOfAcc.SelectedNode.Level == 4)
                {

                    clnWithHeld.Visible = true;
                   
                    DataRow drch = dtChart.Rows.Find(tvChartOfAcc.SelectedNode.Name);

                   

                    
                    string SecondaryCode = drch != null ? drch["withheld"].ToString() : "";

                    //DataRow[] dr = dtSecpAccounts.Select("aclevel = 3  and '" + tvChartOfAcc.SelectedNode.Name + "' like  mainhead + '%' ", "accounttitle");
                    DataRow[] dr = dtSecpAccounts.Select("lvl5 is not null and '" + tvChartOfAcc.SelectedNode.Name + "' like  isnull(accountlike,'~')+'%'", "title");

                    //DataRow[] dr = dtSecpAccounts.Select("aclevel = 5 and accountlike LIKE CASE WHEN SubStr('" + tvChartOfAcc.SelectedNode.Name + "',3,1) <2 THEN SubStr('" + tvChartOfAcc.SelectedNode.Name + "',0,6) ELSE  SubStr('" + tvChartOfAcc.SelectedNode.Name + "',0,3) END ||'%'", "accounttitle");
                    
                        //
                        //
                        //
                     if (tvChartOfAcc.SelectedNode.Name.Substring(0, 3) == "005")
                     {
                         clnWithHeld.DataSource = dtaccountitle.Select("accountid like '002%'").CopyToDataTable();
                         clnWithHeld.DisplayMember = "accounttitle";
                         clnWithHeld.ValueMember = "accountid";
                    }
                    else if (tvChartOfAcc.SelectedNode.Name.Substring(0, 3) == "004")
                    {
                        clnWithHeld.DataSource = dtaccountitle.Select("accountid like '001%'").CopyToDataTable();
                        clnWithHeld.DisplayMember = "accounttitle";
                        clnWithHeld.ValueMember = "accountid";
                    }
                        else
                    {
                        clnWithHeld.DataSource = null;
                    }
                            

                }
                else clnWithHeld.Visible = false;
                   



                dgvAccount.Rows.Clear();
                for (int i = 0; i < dtFilter.Rows.Count; i++)
                {
                    dgvAccount.Rows.Add(dtFilter.Rows[i]["Account"].ToString(), dtFilter.Rows[i]["Title"].ToString(),
                        dtFilter.Rows[i]["withheld"].ToString(),
                        dtFilter.Rows[i]["parentid"].ToString(), dtFilter.Rows[i]["Acctype"].ToString(),
                        dtFilter.Rows[i]["AccLevel"].ToString(),

                        dtFilter.Rows[i]["per"].ToString(),
                        dtFilter.Rows[i]["segregation"].ToString() == "1" ? true : false,
                         dtFilter.Rows[i]["netcapital"].ToString() == "1" ? true : false,
                          dtFilter.Rows[i]["liquidcapital"].ToString() == "1" ? true : false,
                        dtFilter.Rows[i]["CreatedBy"].ToString(),// + " " + (dtFilter.Rows[i]["CreatedTime"].ToString() == "" ? "" : ((DateTime)dtFilter.Rows[i]["CreatedTime"]).ToString("| dd-MMM-yyyy hh:mm:ss tt")),
                        dtFilter.Rows[i]["EditBy"].ToString(),//+ " " + (dtFilter.Rows[i]["EditTime"].ToString() == "" ? "" : ((DateTime)dtFilter.Rows[i]["EditTime"]).ToString("| dd-MMM-yyyy hh:mm:ss tt")),
                        "0");
                    DataRow[] dtSeg = dtFilter.Select("account like '002%'");
                    if (dtSeg.Length > 0)
                    {
                        for (int j = 0; j < dtSeg.Length; j++)
                        {
                            dgvAccount.Rows[i].Cells[ClnSegregation.Index].ReadOnly = false;
                        }
                    }
                    else
                    {
                        dgvAccount.Rows[i].Cells[ClnSegregation.Index].ReadOnly = true;
                    }


                }

                // DataRow[] dtSegregation = dtFilter.Select("account like '002%'");
                // for (int i = 0; i < dtSegregation.Length; i++)
                // {
                //     dgvAccount.Rows[i].Cells[ClnSegregation.Index].ReadOnly = false;
                // }
                AllowRowAdd();
                if (dtFilter.Rows.Count == 0)
                {
                    lbldgvCreated.Text = "-";
                    lbldgvEdit.Text = "-";
                }
            }
        }

        private void tvChartOfAcc_AfterSelect(object sender, TreeViewEventArgs e)
        {
            tvChartOfAcc.SelectedNode.ContextMenuStrip = contextMenuStrip1;
            if (e.Node.Level == 5)
                tvChartOfAcc.SelectedNode.ContextMenuStrip.Items[0].Text = "&Add Into " + e.Node.Parent.Text;
            else
                tvChartOfAcc.SelectedNode.ContextMenuStrip.Items[0].Text = "&Add";
            Filldgv();

        }


