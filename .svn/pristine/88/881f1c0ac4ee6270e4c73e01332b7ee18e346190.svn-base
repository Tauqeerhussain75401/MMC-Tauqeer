        private void frmIPDBilling_Load(object sender, EventArgs e)
        {

            SuspendLayout();
            cmbpackages.AutoCompleteMode = AutoCompleteMode.SuggestAppend;
            cmbpackages.AutoCompleteSource = AutoCompleteSource.ListItems;
            AutoScaleDimensions = new System.Drawing.SizeF(96.0F, 96.0F);
            AutoScaleMode = System.Windows.Forms.AutoScaleMode.Dpi;

            ResumeLayout();
            dtpDischrgeDate.Value = SoftwareInfo.ServerDate;

        }


        void CalcSummary()
        {
            if (chkPackage.Checked == true)
            {
                DataRowView dr = (DataRowView)cmbpackages.SelectedItem;
                decimal packageAmt = 0;
                if (dr != null)
                    packageAmt = (Decimal)dr["amount"];
                ntxtTotalCharges.Value = ntxtMisc.Value + packageAmt;
            }
            else
            {
                ntxtTotalCharges.Value = ntxttotHCharges.Value + ntxttotCcharges.Value;
            }
            ntxtReceivable.Value = ntxtTotalCharges.Value - ntxtDepositAmount.Value - ntxtDiscount.Value;
            ntxtNetBal.Value = ntxtTotalCharges.Value - ntxtDepositAmount.Value - ntxtDiscount.Value + RefundAmount;
            lblRecRefund.Text = ntxtReceivable.Value > 0 ? "Receivable" : "To Be Refunded";

        }
        private void chkPackage_CheckedChanged(object sender, EventArgs e)
        {
            if (chkPackage.Checked)
            {
                grpTotalBill.Text = "Package Bill";
                lbltotalCharges.Text = "Package Charges";
                cmbpackages.Enabled = true;

                if (dt != null && dt.Rows.Count > 0 && dt.Rows[0]["packageid"].ToString() != "")
                    cmbpackages.SelectedValue = dt.Rows[0]["packageid"];
                //else                                   // basit commit 14-04-2021
                // cmbpackages.SelectedIndex = -1;   // basit commit 14-04-2021

            }
            else
            {
                grpTotalBill.Text = "Total Bill";
                lbltotalCharges.Text = "Total Charges";
                pnlConsCharges.Visible = true;
                pnlTotalHosCharges.Visible = true;
                // cmbpackages.SelectedIndex = -1; //basit 12-04-2021
                cmbpackages.Enabled = false;

            }
            CalcSummary();
        }

