        public void Clear()
        {
            Validation.Clear(grpBasicInfo);
            Validation.Clear(grpConsCharges);
            Validation.Clear(grpHosCharges);
            Validation.Clear(grpTotalBill);
            txtRegAlpha.Text = "";
            ntxtRegNo.Text = "";
            txtRegAlpha.Focus();
            chkPackage.Checked = false;
            Validation.Clear(cmbpackages);

            btnPreview.Enabled = true;
            btnPrint.Enabled = true;
            btnSave.Enabled = true;
        }

