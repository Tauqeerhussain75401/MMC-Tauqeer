            PrintReport(true);

        }

        private void btnPreview_Click(object sender, EventArgs e)
        {
            PrintReport(false);
        }

        private void PrintReport(bool DirectPrint)
        {
            try
            {
                ERP.Reports.CrpInPBillMaster rptInPBillMaster = new Reports.CrpInPBillMaster();
                DataSet ds = new DataSet();
                ds = ReportQuery.InPBillMasterPackage(txtSerial.Text);
                ds.Tables[0].TableName = "DtExpVoucher";
                rptInPBillMaster.SetDataSource(ds.Tables[0]);

                rptInPBillMaster.SetParameterValue("pAdmDate", txtSlipDate.Text);
                rptInPBillMaster.SetParameterValue("pDischargeDate", dtpDischrgeDate.Value);
                rptInPBillMaster.SetParameterValue("pUser", UserInfo.UserName);
                rptInPBillMaster.SetParameterValue("pBillNo", txtbillno.Text);
                rptInPBillMaster.SetParameterValue("pAccountType", txtType.Text);
                rptInPBillMaster.SetParameterValue("pPatientName", txtPatientName.Text);
                rptInPBillMaster.SetParameterValue("pRegNo", txtRegAlpha.Text + "" + ntxtRegNo.Value);
                rptInPBillMaster.SetParameterValue("pRoom", txtRoom.Text);
                rptInPBillMaster.SetParameterValue("pConsultant", txtConsultant.Text);
                rptInPBillMaster.SetParameterValue("pBillDate", dtpDate.Value);
                rptInPBillMaster.SetParameterValue("pDeposit", ntxtDepositAmount.Value);
                rptInPBillMaster.SetParameterValue("Discount", ntxtTBdiscount.Value);
                rptInPBillMaster.SetParameterValue("pDischargeby", txtDischargedBY.Text);

                rptInPBillMaster.SetParameterValue("pReceivable", ntxtReceivable.Value);
                rptInPBillMaster.SetParameterValue("pNetBalance", ntxtNetBal.Value);
                //new add parameter
                rptInPBillMaster.SetParameterValue("pDischargeRemarks", txtdischargeRemrks.Text.ToString());
                rptInPBillMaster.SetParameterValue("preferenceName", referenceName);



                if (DirectPrint == false)
                {
                    frmReportView rptview = new frmReportView();
                    rptview.rptViewer.ReportSource = rptInPBillMaster;
                    rptview.Show();
                }
                else
                {
                    rptInPBillMaster.PrintToPrinter(1, false, 1, 9999);
                }
            }
            catch (Exception ex)
            {
                MessageBox.Show(ex.ToString());
            }

        }


