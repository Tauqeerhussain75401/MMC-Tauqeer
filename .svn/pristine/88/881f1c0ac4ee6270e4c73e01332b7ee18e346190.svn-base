        internal void CallChargesDetail(int testid, string hoscharges)
        {

            frmHospitalCharges charges = new frmHospitalCharges();
            charges.HosCharges = hoscharges;
            charges.TestId = testid;
            charges.serialno = txtSerial.Text;
            charges.billno = txtbillno.Text;
            charges.RoomTitle = txtRoom.Text;
            charges.SlipNumber = txtRegAlpha.Text + "-" + ntxtRegNo.Text;
            charges.PackageId = cmbpackages.SelectedValue == null ? "-1" : cmbpackages.SelectedValue.ToString();
            DataRowView dr = (DataRowView)cmbpackages.SelectedItem;
            if (dr != null)
                charges.PackageAmount = (Decimal)dr["amount"];

            //charges.ShowDialog();
            if (charges.ShowDialog() == System.Windows.Forms.DialogResult.OK)
            {
                RefreshValues(txtSerial.Text);
            }

        }


