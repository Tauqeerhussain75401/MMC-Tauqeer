        bool Validation_for_EmptyTexboxes()
        {
            if (ntxtRegNo.Text == "" || txtRegAlpha.Text == "")
            {
                MessageBox.Show("Please Enter Reg No", "Error", MessageBoxButtons.OK, MessageBoxIcon.Error);
                txtRegAlpha.Focus();
                return false;

            }
            return true;
        }

