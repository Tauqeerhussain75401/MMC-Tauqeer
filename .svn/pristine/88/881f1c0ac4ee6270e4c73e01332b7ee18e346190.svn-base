        private void btnCurrRoom_Click(object sender, EventArgs e)
        {
            frmCurRoom frm = new frmCurRoom();
            frm.serialnum = txtSerial.Text;
            frm.ShowDialog();
            DataTable dt = Query.checkCurrentRoom(txtRegAlpha.Text, ntxtRegNo.Text);
            foreach (DataRow row in dt.Rows)
            {
                object value = row["currentRoom"];
                if (value != DBNull.Value)
                {
                    txtCurrentRoom.Visible = true;
                    txtCurrentRoom.Enabled = true;
                    txtCurrentRoom.Text = dt.Rows[0]["currentRoom"].ToString();
                    lblCurRoom.Visible = true;
                    lblCurRoom.Enabled = true;
                }
                else
                {
                    // txtzakatAddBy.Text = "";

                }

            }

        }

        private void ntxtRegNo_TabStopChanged(object sender, EventArgs e)
        {

