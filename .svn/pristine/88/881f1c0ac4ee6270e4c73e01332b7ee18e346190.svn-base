        List<string> fileNumber = new List<string>();
        int UndoRedoIndex = 0;



        public frmIPDBilling()
        {
            InitializeComponent();
            FillControls.FillcmbPackage(cmbpackages);
            //cmbpackages.Enabled = false; //basit 25-09-2020
            dtpDate.Value = SoftwareInfo.ServerDate;//DateTime.Now;
            dtpDischrgeDate.Value = SoftwareInfo.ServerDate;//DateTime.Now;
            dtpDischrgeDate.Enabled = false;

        }
        string referenceName;
        internal void BasicInfo(string regAlpha, string regNum, bool AddLog)
        {
            DataTable dt = Query.AdmInfo(regAlpha, regNum);
            /////////////////////
            if (UserInfo.UserLevel != "Admin" && dt.Rows.Count > 0)
            {
                string currentdate = dtpDate.Value.ToString("dd/MMM/yyyy");
                string admitDate = ((DateTime)dt.Rows[0]["admdate"]).ToString("dd/MMM/yyyy");
                DataTable dtMonthcount = Query.TwoMonthCount(currentdate, admitDate, ntxtRegNo.Text);

                if (dt.Rows[0]["discyn"].ToString() == "1")
                {
                    grpConsCharges.Enabled = false;
                    grpHosCharges.Enabled = false;
                    groupBox5.Enabled = false;
                    pnlDiscount.Enabled = false;
                    zakatDtp.Enabled = false;
                    cmbpackages.Enabled = false;
                    chkPackage.Enabled = false;
                    btnPrint.Enabled = true;
                    btnPreview.Enabled = true;


                }
                else
                {
                    grpConsCharges.Enabled = true;
                    grpHosCharges.Enabled = true;
                    groupBox5.Enabled = true;
                    pnlDiscount.Enabled = true;
                    if (ntxtDiscount.Value > 0)
                    {
                        zakatDtp.Enabled = true;
                    }
                    else
                    {
                        zakatDtp.Enabled = false;
                    }
                    //     
                    cmbpackages.Enabled = true;
                    chkPackage.Enabled = true;
                    grpControls.Enabled = true;
                    btnPrint.Enabled = false;
                    btnPreview.Enabled = false;
                }

                if (Convert.ToInt32(dtMonthcount.Rows[0]["Month"].ToString()) > 2)
                {
                    MessageBox.Show("Please select correct date", "Error", MessageBoxButtons.OK, MessageBoxIcon.Error);
                    btnPreview.Enabled = false;
                    btnPrint.Enabled = false;
                    btnSave.Enabled = false;
                    Clear();
                    return;
                }
            }
            Validation.Clear(this);
            RefundAmount = 0;
            if (dt.Rows.Count > 0)
            {
                pnlDiscount.Enabled = false;
                zakatDtp.Enabled = false;
                txtRegAlpha.Text = regAlpha;
                ntxtRegNo.Text = regNum;
                txtSerial.Text = dt.Rows[0]["admissionid"].ToString();
                txtSlipDate.Text = ((DateTime)dt.Rows[0]["admdate"]).ToString();
                txtType.Text = dt.Rows[0]["patienttype"].ToString();
                txtPatientName.Text = dt.Rows[0]["patientName"].ToString();
                txtRoom.Text = dt.Rows[0]["roomTitle"].ToString();
                txtConsultant.Text = dt.Rows[0]["consultantname"].ToString();
                txtGender.Text = dt.Rows[0]["gender"].ToString();
                txtAge.Text = dt.Rows[0]["age"].ToString();
                txtRemarks.Text = dt.Rows[0]["remarks"].ToString();
                referenceName = dt.Rows[0]["referencename"].ToString();


                foreach (DataRow row in dt.Rows)
                {
                    object value = row["currentRoom"];
                    if (value != DBNull.Value)
                    {
                        txtCurrentRoom.Visible = true;
                        txtCurrentRoom.Enabled = true;
                        txtCurrentRoom.Text = dt.Rows[0]["currentRoom"].ToString();
                        lblCurRoom.Visible = true;
                        lblCurRoom.Enabled = true;
                    }
                    else
                    {
                        // txtzakatAddBy.Text = "";

                    }

                }


                DepositAmount(txtSerial.Text);
                BillDetail(txtSerial.Text);

                if (dt.Rows[0]["patienttype"].ToString() == "ZAKAT")
                {
                    lblDiscount.Text = "ZAKAT";
                    pnlDiscount.Enabled = true;
                    ntxtDiscount.ReadOnly = false;
                    ntxtDiscount.Enabled = true;
                    if (ntxtDiscount.Value > 0)
                    {
                        zakatDtp.Enabled = true;
                    }
                    else
                        zakatDtp.Enabled = false;


                }
                else
                    if (dt.Rows[0]["patienttype"].ToString() == "SPD")
                {
                    lblDiscount.Text = "SPD";
                    pnlDiscount.Enabled = true;
                    ntxtDiscount.ReadOnly = false;
                    ntxtDiscount.Enabled = true;
                    if (ntxtDiscount.Value > 0)
                    {
                        zakatDtp.Enabled = true;
                    }
                    else
                        zakatDtp.Enabled = false;
                }


                bool isdischarge = dt.Rows[0]["discyn"].ToString() == "1" ? true : false;
                chkdischarge.Checked = isdischarge;
                if (isdischarge == true)
                {
                    lbldischarge.Visible = true;
                }
                else
                {
                    lbldischarge.Visible = false;
                }

                if (AddLog)
                {
                    fileNumber.Add(txtRegAlpha.Text + "-" + ntxtRegNo.Value.ToString());
                    UndoRedoIndex = fileNumber.Count - 1;
                }
            }
            else
            {
                lbldischarge.Visible = false;
                chkdischarge.Enabled = true;
                dtpDischrgeDate.Enabled = true;
                grpConsCharges.Enabled = true;
                grpHosCharges.Enabled = true;
                grpTotalBill.Enabled = true;
                txtdischargeRemrks.Enabled = true;
                MessageBox.Show("Admission Not Exist");
                txtRegAlpha.Focus();
            }
            if (txtzakatAddBy.Text.Length != 0)
            {
                zakatDtp.Enabled = false;
            }
        }

        DataTable dt;
        internal void RefreshValues(string AddmissionId)
        {
            dt = Query.BillDetail(AddmissionId);
            if (dt.Rows.Count > 0)
            {
                ntxtPharmacy.Value = (Decimal)dt.Rows[0]["pharmacy"];
                ntxtLaboratory.Value = (Decimal)dt.Rows[0]["laboratory"];
                ntxtRoom.Value = (Decimal)dt.Rows[0]["room"];
                ntxtXRay.Value = (Decimal)dt.Rows[0]["xray"];
                ntxtMedicalServices.Value = (Decimal)dt.Rows[0]["medicalservices"];
                ntxtMisc.Value = (Decimal)dt.Rows[0]["misc"];
                ntxtConsultant.Value = (Decimal)dt.Rows[0]["consulatntcharges"];
                ntxtSurgery.Value = (Decimal)dt.Rows[0]["surgerycharges"];
                ntxtDelivery.Value = (Decimal)dt.Rows[0]["deliverycharges"];
                ntxtUltrasound.Value = (Decimal)dt.Rows[0]["ultrasoundchatges"];
                ntxtPhysio.Value = (Decimal)dt.Rows[0]["physiotherapycharges"];
                ntxtEcho.Value = (Decimal)dt.Rows[0]["echocardio"];
                ntxtNetBal.Value = (Decimal)dt.Rows[0]["netcharges"];
                CalcSummary();
            }
        }
        decimal RefundAmount = 0;
        internal void BillDetail(string AddmissionId)
        {
            dt = Query.BillDetail(AddmissionId);
            if (dt.Rows.Count == 0)
            {
                //DML.ipdbilling_Update("", txtSerial.Text, ref ReturnBillNo);
                DML.ipdbilling_Update(txtSerial.Text);
                dt = Query.BillDetail(AddmissionId);
            }

            /////////////////////
            if (dt.Rows.Count > 0)
            {
                txtbillno.Text = dt.Rows[0]["ipdbillid"].ToString();

                ntxtPharmacy.Value = (Decimal)dt.Rows[0]["pharmacy"];
                ntxtLaboratory.Value = (Decimal)dt.Rows[0]["laboratory"];
                ntxtRoom.Value = (Decimal)dt.Rows[0]["room"];
                ntxtXRay.Value = (Decimal)dt.Rows[0]["xray"];
                ntxtMedicalServices.Value = (Decimal)dt.Rows[0]["medicalservices"];
                ntxtMisc.Value = (Decimal)dt.Rows[0]["misc"];
                ntxtConsultant.Value = (Decimal)dt.Rows[0]["consulatntcharges"];
                ntxtSurgery.Value = (Decimal)dt.Rows[0]["surgerycharges"];
                ntxtDelivery.Value = (Decimal)dt.Rows[0]["deliverycharges"];
                ntxtUltrasound.Value = (Decimal)dt.Rows[0]["ultrasoundchatges"];
                ntxtPhysio.Value = (Decimal)dt.Rows[0]["physiotherapycharges"];
                ntxtEcho.Value = (Decimal)dt.Rows[0]["echocardio"];
                txtLastUpdatedBY.Text = dt.Rows[0]["editby"].ToString();
                foreach (DataRow row in dt.Rows)
                {
                    object value = row["zakatAddBy"];
                    if (value != DBNull.Value)
                    {
                        txtzakatAddBy.Text = dt.Rows[0]["zakatAddBy"].ToString();
                        txtzakatDate.Text = Convert.ToDateTime(dt.Rows[0]["zakatadddatenew"]).ToString("dd-MMM-yyyy hh:mm tt");
                        zakatDtp.Enabled = false;
                    }
                    else
                    {
                        txtzakatAddBy.Text = "";

                    }

                }



                if (dt.Rows[0]["dischargesessionid"].ToString() != null)
                {
                    txtDischargedBY.Text = dt.Rows[0]["dischargesessionid"].ToString();
                }
                else
                    txtDischargedBY.Text = "";

                ntxtDiscount.Value = (Decimal)dt.Rows[0]["totdiscount"];
                txtdischargeRemrks.Text = dt.Rows[0]["remarks"].ToString();
                RefundAmount = Convert.ToDecimal(Validation.DBNullTo(dt.Rows[0]["refundamount"], 0));

                chkPackage.Checked = dt.Rows[0]["ispackage"].ToString() == "1" ? true : false;

                cmbpackages.SelectedValue = dt.Rows[0]["packageid"];



                if (dt.Rows[0]["dischargeyn"].ToString() == "1")
                    dtpDischrgeDate.Value = Convert.ToDateTime(dt.Rows[0]["dischargedate"].ToString());
                else
                {
                    dtpDischrgeDate.Value = SoftwareInfo.ServerDate;
                    dtpDischrgeDate.Enabled = false;
                }




                if (dt.Rows[0]["ispackage"].ToString() == "1")
                {
                    grpTotalBill.Text = "Package Bill";
                    lbltotalCharges.Text = "Package Charges";
                    cmbpackages.SelectedValue = dt.Rows[0]["packageid"];
                    btnSurgeryCharges.Enabled = true;
                }

                CalcSummary();
            }
        }

        private void btnSurgeryValidate1()
        {
            if (cmbpackages.SelectedValue != null && chkPackage.Checked)
                btnSurgeryCharges.Enabled = true;

            DataRowView dr = (DataRowView)cmbpackages.SelectedItem;
            if (dr != null)
            {

                ntxtTotalCharges.Value = (Decimal)dr["amount"];
                CalcSummary();
            }


            else
                btnSurgeryCharges.Enabled = true;

        }
